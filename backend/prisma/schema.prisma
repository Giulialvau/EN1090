generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth (esistente) ---

enum Role {
  USER
  ADMIN
}

model User {
  // Manteniamo UUID string per compatibilità col codice NestJS/JWT esistente.
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  firstName        String
  lastName         String
  role             Role     @default(USER)
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Commessa {
  id           Int          @id @default(autoincrement())
  codice       String       @unique
  titolo       String?
  cliente      String
  descrizione  String?
  exc          String
  responsabile String?
  luogo        String?
  note         String?      @db.Text
  dataApertura DateTime     @default(now())
  dataInizio   DateTime?
  dataFine     DateTime?
  stato        CommessaStato @default(BOZZA)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  materiali      Materiale[]
  documenti      Documento[]
  checklist      Checklist[]
  audits         Audit[]
  attrezzature   Attrezzatura[]
  processi       Processo[]
  pianiControllo PianoControllo[]
  nonConformita  NonConformita[]
  wps            Wps[]
  wpqr           Wpqr[]
  tracciabilita  Tracciabilita[]
}

model Materiale {
  id          Int      @id @default(autoincrement())
  commessaId  Int
  codice      String
  descrizione String
  tipo        String?
  norma       String?
  certificato31 String?
  heatNumber  String?
  lotto       String?
  fornitore   String?
  dataCarico  DateTime?

  certificatoDocumentoId Int?
  certificatoDocumento   Documento? @relation("MaterialeCertificato", fields: [certificatoDocumentoId], references: [id], onDelete: SetNull)

  commessa    Commessa   @relation(fields: [commessaId], references: [id], onDelete: Cascade)
  tracciabilita Tracciabilita[]
  wpsMaterialeBase Wps[] @relation("WpsMateriale")

  @@unique([commessaId, codice])
  @@index([commessaId])
  @@index([certificatoDocumentoId])
}

model Processo {
  id          Int          @id @default(autoincrement())
  commessaId  Int
  tipo        ProcessoTipo
  descrizione String?
  dataInizio  DateTime?
  dataFine    DateTime?
  note        String?      @db.Text

  commessa    Commessa     @relation(fields: [commessaId], references: [id], onDelete: Cascade)

  @@index([commessaId])
}

model Checklist {
  id               Int            @id @default(autoincrement())
  commessaId       Int
  titolo           String
  categoria        String
  fase             String?
  dataCompilazione DateTime       @default(now())
  esito            ChecklistEsito?
  stato            ChecklistStato  @default(APERTA)
  note             String?        @db.Text
  operatore        String?
  // Allegati: JSON array di `{ documentoId?, nome?, note? }`
  allegati         Json?
  // Punti controllo: `[{ id, descrizione, completato?, risposta?, note? }]`
  elementi         Json

  commessa         Commessa       @relation(fields: [commessaId], references: [id], onDelete: Cascade)

  @@index([commessaId])
}

model NonConformita {
  id          Int     @id @default(autoincrement())
  commessaId  Int
  titolo      String
  descrizione String   @db.Text
  tipo        NcTipo
  gravita     NcGravita
  stato       NcStato
  causa       String?
  azione      String?
  note        String?  @db.Text
  dataApertura DateTime @default(now())
  dataChiusura DateTime?

  commessa    Commessa @relation(fields: [commessaId], references: [id], onDelete: Cascade)

  @@index([commessaId])
}

model Documento {
  id                Int                     @id @default(autoincrement())
  commessaId         Int
  nome              String
  tipo              String
  versione          String
  percorsoFile      String
  statoApprovazione DocumentoStatoApprovazione @default(BOZZA)
  note              String?                 @db.Text
  // Allegati/metadati: JSON (es. riferimenti, firme, link)
  allegati          Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  commessa          Commessa                @relation(fields: [commessaId], references: [id], onDelete: Cascade)
  materialiCertificato Materiale[]          @relation("MaterialeCertificato")

  @@index([commessaId])
}

model Audit {
  id         Int       @id @default(autoincrement())
  commessaId Int
  titolo     String
  data       DateTime
  auditor    String
  esito      AuditEsito
  note       String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  commessa   Commessa  @relation(fields: [commessaId], references: [id], onDelete: Cascade)

  @@index([commessaId])
}

model Attrezzatura {
  id               Int      @id @default(autoincrement())
  commessaId       Int?
  nome             String
  matricola        String   @unique
  tipo             String
  descrizione      String?
  dataManutenzione DateTime?
  dataTaratura     DateTime?
  scadenza         DateTime?
  note             String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  commessa          Commessa? @relation(fields: [commessaId], references: [id], onDelete: SetNull)

  @@index([commessaId])
}

model PianoControllo {
  id                 Int                @id @default(autoincrement())
  commessaId          Int
  fase               String
  controlliRichiesti Json
  esito              PianoControlloEsito @default(IN_ATTESA)
  note               String?            @db.Text
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  commessa           Commessa           @relation(fields: [commessaId], references: [id], onDelete: Cascade)

  @@index([commessaId])
}

model Wps {
  id            Int        @id @default(autoincrement())
  commessaId    Int?
  codice        String     @unique
  descrizione   String?
  processo      String
  spessore      String?
  materialeBase String?
  scadenza      DateTime?
  note          String?    @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  commessa      Commessa?  @relation(fields: [commessaId], references: [id], onDelete: SetNull)

  materialeId   Int?
  materiale     Materiale? @relation("WpsMateriale", fields: [materialeId], references: [id], onDelete: SetNull)

  wpqr          Wpqr[]

  @@index([commessaId])
  @@index([materialeId])
}

model Wpqr {
  id            Int        @id @default(autoincrement())
  commessaId    Int?
  codice        String
  saldatore     String
  wpsId         Int
  dataQualifica DateTime
  scadenza      DateTime?
  note          String?    @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  wps           Wps        @relation(fields: [wpsId], references: [id], onDelete: Restrict)
  commessa      Commessa?  @relation(fields: [commessaId], references: [id], onDelete: SetNull)

  @@index([wpsId])
  @@index([commessaId])
}

model Tracciabilita {
  id                    Int       @id @default(autoincrement())
  commessaId            Int
  materialeId           Int
  posizione             String
  quantita              Decimal   @db.Decimal(18, 4)
  descrizioneComponente String?
  riferimentoDisegno    String?
  note                  String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  commessa              Commessa  @relation(fields: [commessaId], references: [id], onDelete: Cascade)
  materiale             Materiale @relation(fields: [materialeId], references: [id], onDelete: Cascade)

  @@index([commessaId])
  @@index([materialeId])
}

// --- EN 1090: enumerazioni ---

enum CommessaStato {
  BOZZA
  IN_CORSO
  SOSPESA
  CHIUSA
}

enum DocumentoStatoApprovazione {
  BOZZA
  IN_REVISIONE
  APPROVATO
  RESPINTO
}

enum ChecklistStato {
  APERTA
  IN_CORSO
  COMPLETATA
  ARCHIVIATA
}

enum ChecklistEsito {
  CONFORME
  NON_CONFORME
  PARZIALE
  NON_APPLICABILE
}

enum NcTipo {
  INTERNA
  ESTERNA
  FORNITORE
  PROCESSO
}

enum NcGravita {
  BASSA
  MEDIA
  ALTA
  CRITICA
}

enum NcStato {
  APERTA
  IN_ANALISI
  IN_CORSO_AZIONI
  CHIUSA
}

enum AuditEsito {
  CONFORME
  NON_CONFORME
  PARZIALE
}

enum PianoControlloEsito {
  IN_ATTESA
  CONFORME
  NON_CONFORME
  NON_APPLICABILE
}

enum ProcessoTipo {
  SALDATURA
  TAGLIO_TERMICO
  VERNICIATURA
  ASSEMBLAGGIO
  MONTAGGIO
  TRATTAMENTO_SUPERFICIALE
}
