generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth (esistente) ---

enum Role {
  USER
  ADMIN
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  firstName        String
  lastName         String
  role             Role     @default(USER)
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// --- EN 1090: enumerazioni ---

enum CommessaStato {
  BOZZA
  IN_CORSO
  SOSPESA
  CHIUSA
}

enum DocumentoStatoApprovazione {
  BOZZA
  IN_REVISIONE
  APPROVATO
  RESPINTO
}

enum ChecklistStato {
  APERTA
  IN_CORSO
  COMPLETATA
  ARCHIVIATA
}

enum NcTipo {
  INTERNA
  ESTERNA
  FORNITORE
  PROCESSO
}

enum NcGravita {
  BASSA
  MEDIA
  ALTA
  CRITICA
}

enum NcStato {
  APERTA
  IN_ANALISI
  IN_CORSO_AZIONI
  CHIUSA
}

enum AuditEsito {
  CONFORME
  NON_CONFORME
  PARZIALE
}

enum PianoControlloEsito {
  IN_ATTESA
  CONFORME
  NON_CONFORME
  NON_APPLICABILE
}

// --- Commesse (hub relazioni EN 1090) ---

model Commessa {
  id          String        @id @default(uuid())
  codice      String        @unique
  cliente     String
  descrizione String?
  dataInizio  DateTime?
  dataFine    DateTime?
  stato       CommessaStato @default(BOZZA)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  materiali      Materiale[]
  documenti      Documento[]
  pianiControllo PianoControllo[]
  nonConformita  NonConformita[]
  audits         Audit[]
  tracciabilita  Tracciabilita[]
  wps            Wps[]
  wpqr           Wpqr[]
  checklists     Checklist[]
}

// --- Materiali (tracciabilità verso commessa) ---

model Materiale {
  id            String          @id @default(uuid())
  codice        String
  descrizione   String
  certificato31 String?
  lotto         String?
  fornitore     String?
  dataCarico    DateTime?
  commessaId    String
  commessa      Commessa        @relation(fields: [commessaId], references: [id], onDelete: Cascade)
  tracciabilita Tracciabilita[]

  @@unique([commessaId, codice])
  @@index([commessaId])
}

// --- Documenti ---

model Documento {
  id                String                     @id @default(uuid())
  nome              String
  tipo              String
  versione          String
  percorsoFile      String
  statoApprovazione DocumentoStatoApprovazione @default(BOZZA)
  commessaId        String
  commessa          Commessa                   @relation(fields: [commessaId], references: [id], onDelete: Cascade)

  @@index([commessaId])
}

// --- Checklist (elementi: JSON array) ---

model Checklist {
  id         String         @id @default(uuid())
  titolo     String
  categoria  String
  stato      ChecklistStato
  elementi   Json
  commessaId String?
  commessa   Commessa?      @relation(fields: [commessaId], references: [id], onDelete: SetNull)

  @@index([commessaId])
}

// --- WPS / WPQR ---

model Wps {
  id            String    @id @default(uuid())
  codice        String    @unique
  descrizione   String?
  processo      String
  spessore      String?
  materialeBase String?
  scadenza      DateTime?
  commessaId    String?
  commessa      Commessa? @relation(fields: [commessaId], references: [id], onDelete: SetNull)
  wpqr          Wpqr[]

  @@index([commessaId])
}

model Wpqr {
  id            String    @id @default(uuid())
  codice        String
  saldatore     String
  wpsId         String
  wps           Wps       @relation(fields: [wpsId], references: [id], onDelete: Restrict)
  dataQualifica DateTime
  scadenza      DateTime?
  commessaId    String?
  commessa      Commessa? @relation(fields: [commessaId], references: [id], onDelete: SetNull)

  @@index([wpsId])
  @@index([commessaId])
}

// --- Qualifiche personale ---

model Qualifica {
  id        String    @id @default(uuid())
  nome      String
  ruolo     String
  scadenza  DateTime?
  documento String?
}

// --- Attrezzature / strumenti ---

model Attrezzatura {
  id               String    @id @default(uuid())
  nome             String
  matricola        String    @unique
  tipo             String
  dataManutenzione DateTime?
  dataTaratura     DateTime?
  scadenza         DateTime?
}

// --- Non conformità ---

model NonConformita {
  id               String    @id @default(uuid())
  titolo           String
  descrizione      String
  tipo             NcTipo
  gravita          NcGravita
  stato            NcStato
  azioniCorrettive String?
  dataApertura     DateTime  @default(now())
  dataChiusura     DateTime?
  commessaId       String
  commessa         Commessa  @relation(fields: [commessaId], references: [id], onDelete: Cascade)

  @@index([commessaId])
}

// --- Audit (ispezioni / verifiche) ---

model Audit {
  id         String     @id @default(uuid())
  titolo     String
  data       DateTime
  auditor    String
  esito      AuditEsito
  note       String?
  commessaId String
  commessa   Commessa   @relation(fields: [commessaId], references: [id], onDelete: Cascade)

  @@index([commessaId])
}

// --- Piani di controllo ---

model PianoControllo {
  id                 String              @id @default(uuid())
  commessaId         String
  fase               String
  controlliRichiesti Json
  esito              PianoControlloEsito
  commessa           Commessa            @relation(fields: [commessaId], references: [id], onDelete: Cascade)

  @@index([commessaId])
}

// --- Tracciabilità (legame materiale–commessa–posizione) ---

model Tracciabilita {
  id          String    @id @default(uuid())
  materialeId String
  materiale   Materiale @relation(fields: [materialeId], references: [id], onDelete: Cascade)
  commessaId  String
  commessa    Commessa  @relation(fields: [commessaId], references: [id], onDelete: Cascade)
  posizione   String
  quantita    Decimal   @db.Decimal(18, 4)

  @@index([materialeId])
  @@index([commessaId])
}
